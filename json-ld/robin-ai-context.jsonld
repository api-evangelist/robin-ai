{
  "@context": {
    "@version": 1.1,
    "schema": "https://schema.org/",
    "robin": "https://raw.githubusercontent.com/api-evangelist/robin-ai/main/vocabulary/",
    "Document": "schema:DigitalDocument",
    "Contract": "robin:Contract",
    "Table": "robin:Table",
    "Template": "robin:Template",
    "Prompt": "robin:Prompt",
    "Citation": "schema:Quotation",
    "Group": "schema:Collection",
    "Organization": "schema:Organization",
    "id": "@id",
    "name": "schema:name",
    "description": "schema:description",
    "type": "schema:additionalType",
    "status": "robin:status",
    "document_status": "robin:documentStatus",
    "processing_status": "robin:processingStatus",
    "created_at": { "@id": "schema:dateCreated", "@type": "schema:DateTime" },
    "updated_at": { "@id": "schema:dateModified", "@type": "schema:DateTime" },
    "started_at": { "@id": "robin:startedAt", "@type": "schema:DateTime" },
    "completed_at": { "@id": "robin:completedAt", "@type": "schema:DateTime" },
    "failed_at": { "@id": "robin:failedAt", "@type": "schema:DateTime" },
    "cancelled_at": { "@id": "robin:cancelledAt", "@type": "schema:DateTime" },
    "document_count": "robin:documentCount",
    "result_count": "robin:resultCount",
    "group": "robin:group",
    "group_id": "robin:groupId",
    "group_name": "robin:groupName",
    "group_type": "robin:groupType",
    "is_private": "robin:isPrivate",
    "prompts": "robin:prompts",
    "prompt_text": "robin:promptText",
    "answer_format": "robin:answerFormat",
    "answer": "robin:answer",
    "citations": "robin:citations",
    "page": "schema:pageStart",
    "text": "schema:text",
    "properties": "schema:additionalProperty",
    "definition_key": "schema:propertyID",
    "value": "schema:value",
    "value_type": "schema:valueRequired"
  }
}
